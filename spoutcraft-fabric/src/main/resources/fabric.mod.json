{
  "schemaVersion": 1,
  "id": "spoutcraft-mod",
  "version": "${version}",
  "name": "Spoutcraft",
  "description": "Automatically downloads and install modded content when joining Spout servers",
  "authors": [
    "Martijn Muijsers",
    "Spoutcraft authors and contributors"
  ],
  "contact": {
    "sources": "https://github.com/ModernSpout/Spoutcraft"
  },
  "license": "See the included LICENSE.txt",
  "icon": "assets/spout/icon.png",
  "environment": "*",
  "accessWidener": "spoutcraft.classtweaker",
  "mixins": [
    {
      "config": "spoutcraft.spout.clientui.resourcepack.loadingoverlay.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.clientui.resourcepack.toast.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.clientview.clientmod.protocol.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.clientview.clientmod.registryidmapping.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.block.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.block.subtypes.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.blockentity.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.blocktype.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.common.registry.codec.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.common.registry.temporarymodification.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.item.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.gamecontent.datadriven.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~26.1.2",
    "java": ">=25"
  }
}
