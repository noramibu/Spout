{
  "schemaVersion": 1,
  "id": "spoutcraft",
  "version": "${version}",
  "name": "Spoutcraft",
  "description": "Automatically downloads and install modded content when joining Spout servers",
  "authors": [
    "Martijn Muijsers",
    "Spoutcraft authors and contributors"
  ],
  "contact": {
    "sources": "https://github.com/ModernSpout/Spoutcraft"
  },
  "license": "See the included LICENSE.txt",
  "icon": "assets/spout/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "spout.client.fabric.Spout"
    ],
    "client": [
      "spout.client.fabric.SpoutClient"
    ]
  },
  "mixins": [
    {
      "config": "spoutcraft.spout.client.fabric.clientview.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.client.fabric.moredatadriven.minecraft.item.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.client.fabric.moredatadriven.minecraft.type.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.client.fabric.moredatadriven.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.client.fabric.ui.loadingoverlay.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.client.fabric.ui.toast.mixins.json",
      "environment": "client"
    },
    {
      "config": "spoutcraft.spout.common.builtincontent.block.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  }
}
